---
import { SITE, SOCIAL_LINKS } from '../config';
import { t } from '../i18n';
import { LANGUAGES, LANGUAGE_META, type Lang } from '../config';
import type { ResumeSectionKey, ResumeSectionMeta } from '../resume.config';
import SocialIcon from '../components/SocialIcon.astro';
import Sprite from '../components/Sprite.astro';
import '../styles/layout.css';
import '../styles/classic-layout.css';

interface Props {
  lang: Lang;
  title?: string;
  currentPage?: string;
  pageKey?: ResumeSectionKey;
  pageMeta?: ResumeSectionMeta;
  layout?: string;
}

const { lang, title, currentPage, pageKey, pageMeta, layout } = Astro.props;
const base = import.meta.env.BASE_URL;
const heroAccent = pageMeta?.accent ?? '#6366f1';
const langOptions = LANGUAGES.filter(code => code !== lang);

const navItems = [
  { key: 'nav.about', href: `${base}${lang}/` },
  { key: 'nav.experience', href: `${base}${lang}/experience` },
  { key: 'nav.education', href: `${base}${lang}/education` },
  { key: 'nav.publications', href: `${base}${lang}/publications` },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={SITE.description} />
    <title>{title ? `${title} · ${SITE.title}` : SITE.title}</title>

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;650;700&display=swap" rel="stylesheet" />

    <!-- Canonical URL -->
    <link rel="canonical" href={`${import.meta.env.SITE}${base}${lang}/${pageKey === 'about' ? '' : pageKey}`} />

    <!-- Hreflang for all language variants -->
    {LANGUAGES.map(code => (
      <link rel="alternate" hreflang={code === 'zh-hant' ? 'zh-Hant' : code} href={`${import.meta.env.SITE}${base}${code}/${pageKey === 'about' ? '' : pageKey}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${import.meta.env.SITE}${base}${lang}/`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title ? `${title} · ${SITE.title}` : SITE.title} />
    <meta property="og:description" content={pageMeta?.summary ?? SITE.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${import.meta.env.SITE}${base}${lang}/${pageKey === 'about' ? '' : pageKey}`} />
    <meta property="og:site_name" content={SITE.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title ? `${title} · ${SITE.title}` : SITE.title} />
    <meta name="twitter:description" content={pageMeta?.summary ?? SITE.description} />

    <!-- JSON-LD Person structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": SITE.title,
      "url": `${import.meta.env.SITE}${base}${lang}/`,
      "knowsAbout": ["Aviation operations", "AI workflow", "Simulation optimization", "Industrial engineering"],
      "alumniOf": ["The Hong Kong Polytechnic University", "Guangdong University of Technology"],
    })} />
  </head>
  <body class={layout === 'classic' ? 'layout-classic' : ''}>
    <Sprite />
    <div class="page-transition" aria-hidden="true">
      <span class="transition-layer layer-a"></span>
      <span class="transition-layer layer-b"></span>
      <span class="transition-layer layer-c"></span>
    </div>
    <div class="cursor-trail" aria-hidden="true"></div>
    <header>
      <nav>
        <a href={`${base}${lang}/`} class="site-title">{SITE.title}</a>
        <button type="button" class="mobile-nav-toggle" aria-expanded="false" aria-controls="primary-nav">
          <span class="mobile-nav-toggle-label">{t(lang, 'nav.menu')}</span>
          <span class="mobile-nav-toggle-icon" aria-hidden="true"></span>
        </button>
        <ul class="nav-links" id="primary-nav">
          {navItems.map(item => (
            <li>
              <a href={item.href} class={currentPage === item.key ? 'active' : ''}>
                {t(lang, item.key)}
              </a>
            </li>
          ))}
        </ul>
        <div class="nav-right">
          <ul class="social-links">
            {SOCIAL_LINKS.map(link => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
                  <SocialIcon icon={link.icon} />
                </a>
              </li>
            ))}
          </ul>
          <div class="lang-menu">
            <button type="button" class="lang-toggle" aria-expanded="false" aria-haspopup="menu" aria-controls="lang-menu-panel">
              {LANGUAGE_META[lang].label}
            </button>
            <div class="lang-menu-panel" id="lang-menu-panel" role="menu">
              {langOptions.map(code => (
                <a href={`${base}${code}/`} role="menuitem">
                  {LANGUAGE_META[code].label} · {LANGUAGE_META[code].name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </nav>
    </header>
    <main data-page-key={pageKey} style={`--page-accent: ${heroAccent};`}>
      <div class="page-frame">
        <slot />
      </div>
    </main>
    <footer>
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} {SITE.title}</span>
        <ul class="footer-social">
          {SOCIAL_LINKS.map(link => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
                <SocialIcon icon={link.icon} />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </footer>
    <script>
      const navElement = document.querySelector('header nav');
      const mobileNavToggle = document.querySelector('.mobile-nav-toggle');
      const langMenu = document.querySelector('.lang-menu');
      const langToggle = document.querySelector('.lang-toggle');
      const langMenuPanel = document.querySelector('.lang-menu-panel');
      const pageTransition = document.querySelector('.page-transition');
      const cursorTrail = document.querySelector('.cursor-trail');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
      const hasAnimationRuntime = typeof window.requestAnimationFrame === 'function';
      const shouldEnableDynamicEffects = hasFinePointer && !prefersReducedMotion && hasAnimationRuntime;

      const closeMobileNav = () => {
        if (!navElement || !mobileNavToggle) return;
        navElement.classList.remove('is-mobile-open');
        mobileNavToggle.setAttribute('aria-expanded', 'false');
      };

      if (navElement && mobileNavToggle) {
        mobileNavToggle.addEventListener('click', () => {
          const isOpen = navElement.classList.toggle('is-mobile-open');
          mobileNavToggle.setAttribute('aria-expanded', String(isOpen));
        });

        navElement.querySelectorAll('.nav-links a, .lang-menu-panel a').forEach(link => {
          link.addEventListener('click', () => closeMobileNav());
        });

        document.addEventListener('click', event => {
          const target = event.target;
          if (!(target instanceof Node) || navElement.contains(target)) return;
          closeMobileNav();
        });

        const desktopMedia = window.matchMedia('(min-width: 901px)');
        const handleDesktopChange = event => {
          if (event.matches) closeMobileNav();
        };

        if (typeof desktopMedia.addEventListener === 'function') {
          desktopMedia.addEventListener('change', handleDesktopChange);
        } else if (typeof desktopMedia.addListener === 'function') {
          desktopMedia.addListener(handleDesktopChange);
        }
      }

      if (langMenu && langToggle) {
        const setLangMenuOpen = isOpen => {
          langMenu.classList.toggle('is-open', isOpen);
          langToggle.setAttribute('aria-expanded', String(isOpen));
        };

        langToggle.addEventListener('click', event => {
          event.preventDefault();
          const nextState = !langMenu.classList.contains('is-open');
          setLangMenuOpen(nextState);
        });

        langMenuPanel?.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => setLangMenuOpen(false));
        });

        document.addEventListener('click', event => {
          const target = event.target;
          if (!(target instanceof Node) || langMenu.contains(target)) return;
          setLangMenuOpen(false);
        });

        langMenu.addEventListener('keydown', event => {
          if (event.key !== 'Escape') return;
          setLangMenuOpen(false);
          langToggle.focus();
        });
      }

      if (cursorTrail && shouldEnableDynamicEffects) {
        document.body.classList.add('has-custom-cursor');
        let latestX = window.innerWidth / 2;
        let latestY = window.innerHeight / 2;
        let renderedX = latestX;
        let renderedY = latestY;

        window.addEventListener('pointermove', event => {
          latestX = event.clientX;
          latestY = event.clientY;
        }, { passive: true });

        const animateCursor = () => {
          renderedX += (latestX - renderedX) * 0.14;
          renderedY += (latestY - renderedY) * 0.14;
          cursorTrail.style.transform = `translate3d(${renderedX - 24}px, ${renderedY - 24}px, 0)`;
          requestAnimationFrame(animateCursor);
        };

        requestAnimationFrame(animateCursor);

        const cursorSafeZone = document.querySelector('.lang-menu');
        if (cursorSafeZone) {
          cursorSafeZone.addEventListener('pointerenter', () => document.body.classList.add('system-cursor-mode'));
          cursorSafeZone.addEventListener('pointerleave', () => document.body.classList.remove('system-cursor-mode'));
        }
      } else {
        document.body.classList.remove('has-custom-cursor');
        cursorTrail?.remove();
      }

      if (pageTransition && shouldEnableDynamicEffects) {
        const setTransitionState = state => pageTransition.classList.toggle('is-active', state);
        window.addEventListener('beforeunload', () => setTransitionState(true));

        document.querySelectorAll('a[href^="/"] , a[href^="."]').forEach(anchor => {
          anchor.addEventListener('click', event => {
            if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || anchor.target === '_blank') return;
            const href = anchor.getAttribute('href');
            if (!href || href.startsWith('#')) return;
            event.preventDefault();
            setTransitionState(true);
            window.setTimeout(() => { window.location.href = anchor.href; }, 280);
          });
        });
      } else {
        pageTransition?.remove();
      }

      const revealTargets = document.querySelectorAll('[data-reveal]');

      if (!shouldEnableDynamicEffects) {
        revealTargets.forEach(element => element.classList.add('visible'));
      } else {
        const observer = new IntersectionObserver(
          entries => entries.forEach(entry => entry.isIntersecting && entry.target.classList.add('visible')),
          { threshold: 0.01, rootMargin: '0px 0px -8% 0px' }
        );

        revealTargets.forEach((element, index) => {
          element.style.setProperty('--reveal-delay', `${Math.min(index * 45, 300)}ms`);
          observer.observe(element);
        });
      }
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg: #ffffff;
    --color-surface: #fafbfc;
    --color-surface-strong: #ffffff;
    --color-text: #0a0a0b;
    --color-muted: #6b7280;
    --color-border: rgba(0,0,0,0.08);
    --color-accent: #6366f1;
    --color-accent-soft: rgba(99,102,241,0.08);
    --color-card: #ffffff;
    --font: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --max-w: 1100px;
    --radius: 12px;
    --shadow-as-border: 0px 0px 0px 1px rgba(0,0,0,0.06);
    --shadow-elevation: 0px 1px 2px rgba(0,0,0,0.04), 0px 4px 8px -2px rgba(0,0,0,0.04);
  }

  body {
    font-family: var(--font);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.has-custom-cursor,
  body.has-custom-cursor * {
    cursor: auto;
  }

  body.has-custom-cursor.system-cursor-mode .cursor-trail {
    opacity: 0;
  }
</style>
