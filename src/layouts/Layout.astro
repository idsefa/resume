---
import { SITE, SOCIAL_LINKS } from '../config';
import { t } from '../i18n';
import { LANGUAGES, LANGUAGE_META, type Lang } from '../config';
import { DEFAULT_THEME, getTheme } from '../config/themes';
import type { ResumeSectionKey, ResumeSectionMeta } from '../resume.config';
import SocialIcon from '../components/SocialIcon.astro';
import Sprite from '../components/Sprite.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import ThemeEffects from '../components/ThemeEffects.astro';
import '../styles/theme.css';
import '../styles/layout.css';
import '../styles/classic-layout.css';
import '../styles/sidebar-layout.css';
import { ROLE_VARIANTS } from '../resume-overrides/roles/index';
import { ROLE_THEME_MAP } from '../config/themes';

interface Props {
  lang: Lang;
  title?: string;
  currentPage?: string;
  pageKey?: ResumeSectionKey;
  pageMeta?: ResumeSectionMeta;
  layout?: string;
  profileName?: string;
  profileRole?: string;
}

const { lang, title, currentPage, pageKey, pageMeta, layout, profileName, profileRole } = Astro.props;
const base = import.meta.env.BASE_URL;
const heroAccent = pageMeta?.accent ?? '#6366f1';
const langOptions = LANGUAGES.filter(code => code !== lang);
const isSidebar = layout === 'sidebar';

const navItems = [
  { key: 'nav.about', href: `${base}${lang}/` },
  { key: 'nav.experience', href: `${base}${lang}/experience` },
  { key: 'nav.education', href: `${base}${lang}/education` },
  { key: 'nav.publications', href: `${base}${lang}/publications` },
];

const defaultTheme = DEFAULT_THEME;
const defaultBodyClass = getTheme(defaultTheme).bodyClass;

const initials = (profileName ?? SITE.title).split(' ').map((w: string) => w[0]).slice(0, 2).join('').toUpperCase();

const roleVariantsJson = JSON.stringify(
  Object.entries(ROLE_VARIANTS).map(([id, v]) => ({
    id,
    label: v.label,
    profileRole: v.profileRole,
    highlights: v.highlights,
    experienceSummary: v.experienceSummary,
    educationSummary: v.educationSummary,
  }))
);
---

<!doctype html>
<html lang={lang} data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={SITE.description} />
    <title>{title ? `${title} · ${SITE.title}` : SITE.title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;650;700&display=swap" rel="stylesheet" />

    <link rel="canonical" href={`${import.meta.env.SITE}${base}${lang}/${pageKey === 'about' ? '' : pageKey}`} />
    {LANGUAGES.map(code => (
      <link rel="alternate" hreflang={code === 'zh-hant' ? 'zh-Hant' : code} href={`${import.meta.env.SITE}${base}${code}/${pageKey === 'about' ? '' : pageKey}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${import.meta.env.SITE}${base}${lang}/`} />

    <meta property="og:title" content={title ? `${title} · ${SITE.title}` : SITE.title} />
    <meta property="og:description" content={pageMeta?.summary ?? SITE.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${import.meta.env.SITE}${base}${lang}/${pageKey === 'about' ? '' : pageKey}`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title ? `${title} · ${SITE.title}` : SITE.title} />
    <meta name="twitter:description" content={pageMeta?.summary ?? SITE.description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": SITE.title,
      "url": `${import.meta.env.SITE}${base}${lang}/`,
    })} />
  </head>
  <body class={`${isSidebar ? 'layout-sidebar' : layout === 'classic' ? 'layout-classic' : ''} ${defaultBodyClass}`}>
    <Sprite />
    {!isSidebar && (
      <div class="page-transition" aria-hidden="true">
        <span class="transition-layer layer-a"></span>
        <span class="transition-layer layer-b"></span>
        <span class="transition-layer layer-c"></span>
      </div>
    )}
    <div class="cursor-trail" aria-hidden="true"></div>

    <!-- Shared header for all layouts -->
    <header class={isSidebar ? 'header-compact' : ''}>
      <nav>
        {!isSidebar && (
          <>
            <a href={`${base}${lang}/`} class="site-title">{SITE.title}</a>
            <button type="button" class="mobile-nav-toggle" aria-expanded="false" aria-controls="primary-nav">
              <span class="mobile-nav-toggle-label">{t(lang, 'nav.menu')}</span>
              <span class="mobile-nav-toggle-icon" aria-hidden="true"></span>
            </button>
            <ul class="nav-links" id="primary-nav">
              {navItems.map(item => (
                <li>
                  <a href={item.href} class={currentPage === item.key ? 'active' : ''}>{t(lang, item.key)}</a>
                </li>
              ))}
            </ul>
          </>
        )}
        <div class="nav-right">
          <div class="role-switcher" id="roleSwitcher">
            <button type="button" class="role-toggle" id="roleToggle" aria-expanded="false" aria-haspopup="menu" aria-controls="role-menu-panel">
              <span class="role-toggle-label" id="roleToggleLabel">{(lang === 'zh' || lang === 'zh-hant') ? '通用' : 'General'}</span>
              <span class="role-toggle-arrow">▾</span>
            </button>
            <div class="role-menu-panel" id="role-menu-panel" role="menu">
              {Object.entries(ROLE_VARIANTS).map(([id, v]) => (
                <button type="button" class={`role-option${id === 'default' ? ' is-active' : ''}`} data-role-id={id} role="menuitem">
                  <span class="role-option-label">{(lang === 'zh' || lang === 'zh-hant') ? (v.labelZh || v.label) : v.label}</span>
                </button>
              ))}
            </div>
          </div>
          <div class="layout-switcher" id="layoutSwitcher">
            <button type="button" class="layout-toggle" id="layoutToggle" aria-expanded="false" aria-haspopup="menu" aria-controls="layout-menu-panel">
              <span class="layout-toggle-icon" id="layoutToggleIcon">◧</span>
              <span class="layout-toggle-label" id="layoutToggleLabel">Sidebar</span>
              <span class="role-toggle-arrow">▾</span>
            </button>
            <div class="layout-menu-panel" id="layout-menu-panel" role="menu">
              <button type="button" class="layout-option" data-layout="sidebar" role="menuitem"><span class="layout-option-icon">◧</span><span>Sidebar</span></button>
              <button type="button" class="layout-option" data-layout="centered" role="menuitem"><span class="layout-option-icon">▦</span><span>Centered Hero</span></button>
              <button type="button" class="layout-option" data-layout="classic" role="menuitem"><span class="layout-option-icon">▤</span><span>Classic List</span></button>
              <button type="button" class="layout-option" data-layout="dramatic" role="menuitem"><span class="layout-option-icon">▩</span><span>Full-bleed Hero</span></button>
              <button type="button" class="layout-option" data-layout="glass" role="menuitem"><span class="layout-option-icon">◌</span><span>Overlapping Sections</span></button>
              <button type="button" class="layout-option" data-layout="zen" role="menuitem"><span class="layout-option-icon">○</span><span>Minimal Zen</span></button>
            </div>
          </div>
          <ThemeToggle {lang} />
          <button type="button" class="pdf-export-btn" id="pdfExportBtn" aria-label="Export PDF">
            <span class="pdf-icon">⬇</span> PDF
          </button>
          <div class="lang-menu">
            <button type="button" class="lang-toggle" aria-expanded="false" aria-haspopup="menu" aria-controls="lang-menu-panel">
              {LANGUAGE_META[lang].label}
            </button>
            <div class="lang-menu-panel" id="lang-menu-panel" role="menu">
              {langOptions.map(code => (
                <a href={`${base}${code}/`} role="menuitem">
                  {LANGUAGE_META[code].label} · {LANGUAGE_META[code].name}
                </a>
              ))}
            </div>
          </div>
          {!isSidebar && (
            <ul class="social-links">
              {SOCIAL_LINKS.map(link => (
                <li>
                  <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
                    <SocialIcon icon={link.icon} />
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </nav>
    </header>

    {isSidebar ? (
      <>
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <aside class="sidebar" id="sidebar">
          <div class="sidebar-inner">

            <div class="sidebar-identity">
              <div class="sidebar-initials" aria-hidden="true">{initials}</div>
              <div class="sidebar-name">{profileName ?? SITE.title}</div>
              <div class="sidebar-role" id="sidebarRole">{profileRole ?? ''}</div>
            </div>

            <nav class="sidebar-nav" aria-label="Section navigation">
              <div class="sidebar-section-label">Navigation</div>
              <ul class="sidebar-nav-links">
                {navItems.map(item => (
                  <li>
                    <a href={item.href} class={currentPage === item.key ? 'active' : ''}>
                      <span class="sidebar-nav-dot" aria-hidden="true"></span>
                      {t(lang, item.key)}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            <div class="sidebar-contact">
              <div class="sidebar-section-label">Links</div>
              <ul class="sidebar-contact-list">
                {SOCIAL_LINKS.map(link => (
                  <li>
                    <span class="contact-icon" aria-hidden="true">↗</span>
                    <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </aside>

        <main data-page-key={pageKey} style={`--page-accent: ${heroAccent};`}>
          <div class="page-frame"><slot /></div>
        </main>
      </>
    ) : (
      <>
        <main data-page-key={pageKey} style={`--page-accent: ${heroAccent};`}>
          <div class="page-frame"><slot /></div>
        </main>
        <footer>
          <div class="footer-inner">
            <span>© {new Date().getFullYear()} {SITE.title}</span>
            <ul class="footer-social">
              {SOCIAL_LINKS.map(link => (
                <li>
                  <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
                    <SocialIcon icon={link.icon} />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </footer>
      </>
    )}

    <ThemeEffects />

    <script define:vars={{ roleVariantsJson, isSidebar }}>
      // ---- Theme ----
      const THEME_ICONS = {
        'light-tech':'☀️','classic':'📜','dark-olive':'🌿','midnight':'🌙','rose':'🌹',
        'cyber-neon':'🌆','frosted-glass':'🫧','warm-retro':'🕰️','arctic-tech':'🧊',
        'forest-canopy':'🌲','abyssal-depths':'🐋','crimson-noir':'🥀','matcha-zen':'🍵',
        'neo-brutal':'⬛','catppuccin':'🐱','dracula':'🧛','whiteboard':'📋',
      };
      const ALL_THEMES = Object.keys(THEME_ICONS);
      const THEME_KEY = 'resume-theme';
      const ROLE_KEY = 'resume-role';

      // Role → recommended theme mapping
      const ROLE_THEME_MAP = {
        'default': 'light-tech',
        'aviation': 'arctic-tech',
        'consulting': 'classic',
        'engineering': 'dark-olive',
        'ai': 'cyber-neon',
        'quant': 'midnight',
        'audit': 'matcha-zen',
      };

      function applyTheme(id) {
        document.documentElement.setAttribute('data-theme', id);
        const el = document.getElementById('themeToggleIcon');
        if (el) el.textContent = THEME_ICONS[id] || '☀️';
        try { localStorage.setItem(THEME_KEY, id); } catch(_) {}
        document.querySelectorAll('.theme-option').forEach(o => o.classList.toggle('is-active', o.getAttribute('data-theme-id') === id));
        if (window.__applyThemeEffects) window.__applyThemeEffects(id);
      }

      let saved; try { saved = localStorage.getItem(THEME_KEY); } catch(_) {}
      if (saved && ALL_THEMES.includes(saved)) applyTheme(saved);

      const themeBtn = document.getElementById('themeToggle');
      const themePicker = document.getElementById('themePicker');
      if (themeBtn && themePicker) {
        themeBtn.addEventListener('click', e => { e.stopPropagation(); themePicker.classList.toggle('is-open'); });
        themePicker.querySelectorAll('.theme-option').forEach(o => {
          o.addEventListener('click', () => { applyTheme(o.getAttribute('data-theme-id')); themePicker.classList.remove('is-open'); });
        });
        document.addEventListener('click', e => { if (!themeBtn.contains(e.target) && !themePicker.contains(e.target)) themePicker.classList.remove('is-open'); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') themePicker.classList.remove('is-open'); });
      }

      // ---- Lang menu ----
      const langMenu = document.querySelector('.lang-menu');
      const langToggle = document.querySelector('.lang-toggle');
      const langPanel = document.querySelector('.lang-menu-panel');
      if (langMenu && langToggle) {
        const setOpen = v => { langMenu.classList.toggle('is-open', v); langToggle.setAttribute('aria-expanded', String(v)); };
        langToggle.addEventListener('click', e => { e.preventDefault(); setOpen(!langMenu.classList.contains('is-open')); });
        langPanel?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)));
        document.addEventListener('click', e => { if (!langMenu.contains(e.target)) setOpen(false); });
        langMenu.addEventListener('keydown', e => { if (e.key === 'Escape') { setOpen(false); langToggle.focus(); } });
      }

      // ---- Mobile nav (non-sidebar) ----
      if (!isSidebar) {
        const navEl = document.querySelector('header nav');
        const mobileToggle = document.querySelector('.mobile-nav-toggle');
        const closeNav = () => { navEl?.classList.remove('is-mobile-open'); mobileToggle?.setAttribute('aria-expanded', 'false'); };
        if (navEl && mobileToggle) {
          mobileToggle.addEventListener('click', () => { const o = navEl.classList.toggle('is-mobile-open'); mobileToggle.setAttribute('aria-expanded', String(o)); });
          navEl.querySelectorAll('.nav-links a, .lang-menu-panel a').forEach(a => a.addEventListener('click', closeNav));
          document.addEventListener('click', e => { if (!navEl.contains(e.target)) closeNav(); });
        }
      }

      // ---- Sidebar mobile toggle ----
      if (isSidebar) {
        const sidebar = document.getElementById('sidebar');
        const toggle = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');
        const close = () => { sidebar?.classList.remove('is-open'); overlay?.classList.remove('is-open'); toggle?.classList.remove('is-open'); toggle?.setAttribute('aria-expanded', 'false'); };
        toggle?.addEventListener('click', () => {
          const open = sidebar?.classList.toggle('is-open');
          overlay?.classList.toggle('is-open', open);
          toggle.classList.toggle('is-open', open);
          toggle.setAttribute('aria-expanded', String(open));
        });
        overlay?.addEventListener('click', close);
        document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
      }

      // ---- PDF Export ----
      const pdfBtn = document.getElementById('pdfExportBtn');
      if (pdfBtn) {
        pdfBtn.addEventListener('click', () => {
          const lang = location.pathname.split('/')[1] || 'en';
          window.open('/' + lang + '/pdf', '_blank');
        });
      }
      // ---- Role switcher (all layouts) ----
      const ROLES = JSON.parse(roleVariantsJson);
      const roleMap = Object.fromEntries(ROLES.map(v => [v.id, v]));
      let currentRole = 'default';

        // Priority: URL param > localStorage > default
        const urlRole = new URLSearchParams(location.search).get('role');
        if (urlRole && roleMap[urlRole]) {
          currentRole = urlRole;
          try { localStorage.setItem(ROLE_KEY, urlRole); } catch(_) {}
        } else {
          try { const s = localStorage.getItem(ROLE_KEY); if (s && roleMap[s]) currentRole = s; } catch(_) {}
        }

        function applyRole(id) {
          const v = roleMap[id];
          if (!v) return;
          currentRole = id;
          try { localStorage.setItem(ROLE_KEY, id); } catch(_) {}

          // Update URL without reload
          const url = new URL(location.href);
          if (id === 'default') url.searchParams.delete('role');
          else url.searchParams.set('role', id);
          history.replaceState(null, '', url);

          // Auto-switch theme to match role
          const recommendedTheme = ROLE_THEME_MAP[id];
          if (recommendedTheme) applyTheme(recommendedTheme);

          // Detect current language from URL
          const currentLang = location.pathname.split('/')[1] || 'en';
          const langSuffix = currentLang === 'zh' ? 'Zh' : currentLang === 'zh-hant' ? 'ZhHant' : currentLang === 'de' ? 'De' : currentLang === 'fr' ? 'Fr' : '';

          // Sidebar role line
          const roleEl = document.getElementById('sidebarRole');
          if (roleEl) roleEl.textContent = v['profileRole' + langSuffix] || v.profileRole;

          // Active pill
          document.querySelectorAll('.role-option').forEach(b => b.classList.toggle('is-active', b.getAttribute('data-role-id') === id));
          const roleLabel = document.getElementById('roleToggleLabel');
          if (roleLabel) roleLabel.textContent = v['label' + (langSuffix === 'Zh' ? 'Zh' : langSuffix === 'ZhHant' ? 'ZhHant' : '')] || v.label;

          // Highlights (about page)
          const highlights = v['highlights' + langSuffix] || v.highlights;
          document.querySelectorAll('.highlight-card').forEach((card, i) => {
            if (!highlights[i]) return;
            const t = card.querySelector('.highlight-title');
            const d = card.querySelector('.highlight-description');
            if (t) t.textContent = highlights[i].title;
            if (d) d.textContent = highlights[i].description;
          });

          // Page header summary (experience / education)
          const pageKey = document.querySelector('main')?.getAttribute('data-page-key');
          const summaryEl = document.querySelector('.page-header-summary');
          if (summaryEl) {
            const expSummary = v['experienceSummary' + langSuffix] || v.experienceSummary;
            const eduSummary = v['educationSummary' + langSuffix] || v.educationSummary;
            if (pageKey === 'experience' && expSummary?.[0]) summaryEl.textContent = expSummary[0];
            else if (pageKey === 'education' && eduSummary?.[0]) summaryEl.textContent = eduSummary[0];
          }

          document.dispatchEvent(new CustomEvent('rolechange', { detail: { id, variant: v } }));
        }

        if (currentRole !== 'default') applyRole(currentRole);
        document.querySelectorAll('.role-option').forEach(b => b.addEventListener('click', () => {
          applyRole(b.getAttribute('data-role-id'));
          document.getElementById('roleSwitcher')?.classList.remove('is-open');
        }));

        // Role toggle dropdown
        const roleSwitcher = document.getElementById('roleSwitcher');
        const roleToggle = document.getElementById('roleToggle');
        if (roleSwitcher && roleToggle) {
          roleToggle.addEventListener('click', e => { e.stopPropagation(); roleSwitcher.classList.toggle('is-open'); });
          document.addEventListener('click', e => { if (!roleSwitcher.contains(e.target)) roleSwitcher.classList.remove('is-open'); });
          document.addEventListener('keydown', e => { if (e.key === 'Escape') roleSwitcher.classList.remove('is-open'); });
        }

      // ---- Layout switcher ----
      const LAYOUT_KEY = 'resume-layout';
      const LAYOUT_ICONS = { sidebar: '◧', centered: '▦', classic: '▤', dramatic: '▩', glass: '◌', zen: '○' };
      const LAYOUT_LABELS = { sidebar: 'Sidebar', centered: 'Centered Hero', classic: 'Classic List', dramatic: 'Full-bleed Hero', glass: 'Overlapping', zen: 'Minimal Zen' };

      const layoutSwitcher = document.getElementById('layoutSwitcher');
      const layoutToggle = document.getElementById('layoutToggle');
      const layoutPanel = document.getElementById('layout-menu-panel');
      const layoutIcon = document.getElementById('layoutToggleIcon');

      if (layoutSwitcher && layoutToggle && layoutPanel) {
        // Load saved layout
        let currentLayout = 'sidebar';
        try { const s = localStorage.getItem(LAYOUT_KEY); if (s && LAYOUT_ICONS[s]) currentLayout = s; } catch(_) {}

        function applyLayout(id) {
          currentLayout = id;
          try { localStorage.setItem(LAYOUT_KEY, id); } catch(_) {}

          // Mark that user has manually chosen a layout (prevents theme override)
          document.body.setAttribute('data-user-layout', id);

          // Update icon
          if (layoutIcon) layoutIcon.textContent = LAYOUT_ICONS[id] || '◧';
          const layoutLabel = document.getElementById('layoutToggleLabel');
          if (layoutLabel) layoutLabel.textContent = LAYOUT_LABELS[id] || 'Sidebar';

          // Update active state
          layoutPanel.querySelectorAll('.layout-option').forEach(o => {
            o.classList.toggle('is-active', o.getAttribute('data-layout') === id);
          });

          const sidebar = document.getElementById('sidebar');
          const sidebarOv = document.getElementById('sidebarOverlay');
          const sidebarTg = document.getElementById('sidebarToggle');
          const header = document.querySelector('header');
          const footer = document.querySelector('footer');
          const main = document.querySelector('main');
          const pageContent = document.querySelector('.page-content');

          if (id === 'sidebar') {
            // Show sidebar
            sidebar?.style.removeProperty('display');
            sidebarOv?.style.removeProperty('display');
            sidebarTg?.style.removeProperty('display');
            document.body.classList.add('layout-sidebar');
            document.body.classList.remove('layout-classic');
            if (header) header.style.cssText = '';
            if (footer) footer.style.display = 'none';
            if (main) main.style.cssText = '';
            if (pageContent) {
              pageContent.setAttribute('data-page-variant', 'sidebar');
              pageContent.style.cssText = '';
            }
          } else {
            // Hide sidebar, show header/footer
            if (sidebar) sidebar.style.display = 'none';
            if (sidebarOv) sidebarOv.style.display = 'none';
            if (sidebarTg) sidebarTg.style.display = 'none';
            document.body.classList.remove('layout-sidebar');
            if (header) header.style.cssText = '';
            if (footer) footer.style.display = '';
            if (main) main.style.cssText = '';
            if (pageContent) {
              pageContent.setAttribute('data-page-variant', id);
              pageContent.style.cssText = '';
            }
            // Re-trigger reveal animations
            document.querySelectorAll('[data-reveal]').forEach(el => el.classList.add('visible'));
          }

          document.dispatchEvent(new CustomEvent('layoutchange', { detail: { id } }));
        }

        // Apply saved layout on load
        if (currentLayout !== 'sidebar') applyLayout(currentLayout);
        else {
          // Set initial active state for sidebar
          layoutPanel.querySelectorAll('.layout-option').forEach(o => {
            o.classList.toggle('is-active', o.getAttribute('data-layout') === 'sidebar');
          });
        }

        // Toggle panel
        layoutToggle.addEventListener('click', e => {
          e.stopPropagation();
          layoutSwitcher.classList.toggle('is-open');
        });
        layoutPanel.querySelectorAll('.layout-option').forEach(o => {
          o.addEventListener('click', () => {
            applyLayout(o.getAttribute('data-layout'));
            layoutSwitcher.classList.remove('is-open');
          });
        });
        document.addEventListener('click', e => {
          if (!layoutSwitcher.contains(e.target)) layoutSwitcher.classList.remove('is-open');
        });
        document.addEventListener('keydown', e => {
          if (e.key === 'Escape') { layoutSwitcher.classList.remove('is-open'); layoutToggle.focus(); }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg: var(--theme-bg, #ffffff);
    --color-surface: var(--theme-surface, #fafbfc);
    --color-surface-strong: var(--theme-surface-strong, #ffffff);
    --color-text: var(--theme-text, #0a0a0b);
    --color-muted: var(--theme-muted, #6b7280);
    --color-border: var(--theme-border, rgba(0,0,0,0.08));
    --color-accent: var(--theme-accent, #6366f1);
    --color-accent-soft: var(--theme-accent-soft, rgba(99,102,241,0.08));
    --color-card: var(--theme-card, #ffffff);
    --font: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --max-w: 1100px;
