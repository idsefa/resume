---
import type { Lang } from '../../config';
import { LANGUAGES } from '../../config';
import { getResumeContent } from '../../resume-data';
import { SECTION_META } from '../../resume.config';
import { t } from '../../i18n';
import PageShell from '../../components/PageShell.astro';
import '../../styles/resume-pages.css';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const content = getResumeContent(lang);
const config = SECTION_META[lang].publications;
const nextLabel = SECTION_META[lang].about.arrowLabel;
const expData = getResumeContent(lang).experience;
const eduData = getResumeContent(lang).education;
---

<PageShell
  lang={lang}
  title={config.arrowLabel}
  currentPage="nav.publications"
  pageKey="publications"
  pageMeta={config}
  heroKicker={config.kicker}
  heroTitle={config.arrowLabel}
  heroSummary={content.publications.summary[0]}
  experienceCount={expData.items.length}
  educationCount={eduData.items.length}
  arrowLabels={[config.arrowLabel, t(lang, 'arrow.works'), t(lang, 'arrow.impact')]}
  ctaHref={`/${lang}/`}
  ctaLabel={nextLabel}
  profileName={content.profile.name}
  profileRole={content.profile.role}
>
  <section class="pub-sections" data-reveal>
    <div class="section-header">
      <span class="section-number">01</span>
      <span class="section-title-text">{config.arrowLabel}</span>
    </div>
    {content.publications.sections.map((section, sectionIndex) => (
      <div class="pub-group" data-reveal data-stagger={sectionIndex}>
        <h2 class="pub-group-title">{section.title}</h2>
        <div class="pub-list">
          {section.items.map(item => (
            <article class="pub-card">
              <h3 class="pub-title">{item.title}</h3>
              <p class="pub-meta">{item.authors} · {item.venue} · {item.year}</p>
              <div class="pub-links">
                {item.links.map(link => (
                  <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</PageShell>
