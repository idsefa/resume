---
import type { Lang } from '../../config';
import { LANGUAGES, NAVIGATION_SITE_URL } from '../../config';
import { SECTION_META } from '../../resume.config';
import { t } from '../../i18n';
import PageShell from '../../components/PageShell.astro';
import '../../styles/resume-pages.css';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const pageMeta = SECTION_META[lang].about;
---

<PageShell
  lang={lang}
  title="Navigator"
  currentPage="nav.navigator"
  pageKey="about"
  pageMeta={pageMeta}
  heroKicker={t(lang, 'nav.navigator')}
  heroTitle={t(lang, 'nav.jump')}
  heroSummary={t(lang, 'nav.redirect')}
  arrowLabels={[t(lang, 'nav.navigator'), t(lang, 'arrow.links'), t(lang, 'arrow.resources')]}
  ctaHref={NAVIGATION_SITE_URL}
  ctaLabel={t(lang, 'nav.open')}
>
  <div id="navigator-target" data-url={NAVIGATION_SITE_URL} style="display:none"></div>
  <script>
    const el = document.getElementById('navigator-target');
    const url = el?.getAttribute('data-url');
    if (url) {
      window.setTimeout(() => { window.location.href = url; }, 3000);
    }
  </script>
</PageShell>
