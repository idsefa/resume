---
import type { Lang } from '../../config';
import { LANGUAGES } from '../../config';
import { getResumeContent } from '../../resume-data';
import { SECTION_META } from '../../resume.config';
import { t } from '../../i18n';
import PageShell from '../../components/PageShell.astro';
import '../../styles/resume-pages.css';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const content = getResumeContent(lang);
const config = SECTION_META[lang].education;
const nextLabel = SECTION_META[lang].publications.arrowLabel;
const expData = getResumeContent(lang).experience;
const eduData = getResumeContent(lang).education;
---

<PageShell
  lang={lang}
  title={config.arrowLabel}
  currentPage="nav.education"
  pageKey="education"
  pageMeta={config}
  heroKicker={config.kicker}
  heroTitle={config.arrowLabel}
  heroSummary={content.education.summary[0]}
  experienceCount={expData.items.length}
  educationCount={eduData.items.length}
  arrowLabels={[config.arrowLabel, t(lang, 'arrow.study'), t(lang, 'arrow.depth')]}
  ctaHref={`/${lang}/publications`}
  ctaLabel={nextLabel}
  profileName={content.profile.name}
  profileRole={content.profile.role}
>
  <section class="timeline-section" data-reveal>
    <div class="section-header">
      <span class="section-number">01</span>
      <span class="section-title-text">{config.arrowLabel}</span>
    </div>
    <div class="timeline">
      {content.education.items.map((item, idx) => (
        <article class="timeline-item" data-reveal data-stagger={idx}>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3 class="timeline-title">{item.title}</h3>
            <p class="timeline-org">{item.org}</p>
            <p class="timeline-period">{item.period} • {item.location}</p>
            <ul class="timeline-bullets">
              {item.bullets.map(bullet => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>
</PageShell>
