---
const ALLOWED_ICONS = ['github', 'linkedin', 'scholar', 'orcid', 'navigation'] as const;
type IconName = typeof ALLOWED_ICONS[number];

interface Props { icon: IconName; }
const { icon } = Astro.props;
const safeIcon = ALLOWED_ICONS.includes(icon) ? icon : 'navigation';
---
<svg viewBox="0 0 24 24" aria-hidden="true">
  <use href={`#icon-${safeIcon}`} />
</svg>
