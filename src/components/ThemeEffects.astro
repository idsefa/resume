---
// ThemeEffects.astro — Injects per-theme JS behaviors
// The main applyTheme() function in Layout.astro calls these
// based on the current theme's effects profile.
---

<script>
  // ============================================
  // Theme Effects Engine
  // ============================================
  // Maps theme IDs to their effect profiles
  const THEME_PROFILES = {
    'light-tech':    { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'classic':       { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'dark-olive':    { cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'fade', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'midnight':      { cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'slide-left', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'rose':          { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'cyber-neon':    { cursor: 'square-follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'frosted-glass': { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'fade', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'warm-retro':    { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'arctic-tech':   { cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'slide-left', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'forest-canopy': { cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'fade', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'abyssal-depths':{ cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'slide-up', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'crimson-noir':  { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'zoom', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'matcha-zen':    { cursor: 'none', pageTransition: true, parallax: false, countUp: true, revealStyle: 'fade', glitch: false, noise: false, scanlines: false, magnetic: false , floating: true },
    'neo-brutal':    { cursor: 'follower', pageTransition: true, parallax: false, countUp: true, revealStyle: 'slide-up', glitch: true, noise: true, scanlines: false, magnetic: true , floating: true },
    'catppuccin':    { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'fade', glitch: false, noise: true, scanlines: false, magnetic: false , floating: true },
    'dracula':       { cursor: 'follower', pageTransition: true, parallax: true, countUp: true, revealStyle: 'slide-left', glitch: false, noise: false, scanlines: true, magnetic: true , floating: true },
    'whiteboard':    { cursor: 'trail', pageTransition: true, parallax: false, countUp: true, revealStyle: 'fade', glitch: false, noise: false, scanlines: false, magnetic: true , floating: true },
  };

  // Maps theme IDs to their page layout variant
  const THEME_VARIANTS = {
    'light-tech': 'centered', 'midnight': 'centered', 'arctic-tech': 'centered', 'catppuccin': 'centered', 'dracula': 'centered',
    'classic': 'classic', 'rose': 'classic', 'warm-retro': 'classic', 'crimson-noir': 'classic', 'neo-brutal': 'classic',
    'dark-olive': 'dramatic', 'cyber-neon': 'dramatic', 'abyssal-depths': 'dramatic',
    'frosted-glass': 'glass', 'forest-canopy': 'glass',
    'matcha-zen': 'zen',
    'whiteboard': 'whiteboard',
  };

  // Get current theme from <html> data-theme
  function getCurrentThemeId() {
    return document.documentElement.getAttribute('data-theme') || 'light-tech';
  }

  function getProfile(id) {
    return THEME_PROFILES[id] || THEME_PROFILES['light-tech'];
  }

  // Apply theme effects — called by applyTheme() after setting data-theme
  window.__applyThemeEffects = function(themeId) {
    const profile = getProfile(themeId);

    // Set page layout variant on article (but don't override user's layout choice)
    const pageContent = document.querySelector('.page-content');
    if (pageContent) {
      const userLayout = document.body.getAttribute('data-user-layout');
      if (!userLayout) {
        const currentVariant = pageContent.getAttribute('data-page-variant');
        if (currentVariant !== 'sidebar') {
          const variant = THEME_VARIANTS[themeId] || 'centered';
          pageContent.setAttribute('data-page-variant', variant);
        }
      }
    }

    // Set reveal style on body
    document.body.setAttribute('data-reveal-style', profile.revealStyle);

    // Set body class — preserve layout-sidebar
    const body = document.body;
    const hadLayoutSidebar = body.classList.contains('layout-sidebar');
    // Remove all theme-* classes
    Array.from(body.classList).filter(c => c.startsWith('theme-')).forEach(c => body.classList.remove(c));
    body.classList.add('theme-' + themeId);
    // Ensure layout class is preserved
    if (hadLayoutSidebar && !body.classList.contains('layout-sidebar')) {
      body.classList.add('layout-sidebar');
    }

    // Cursor: re-init with the right style
    initCursor(profile.cursor);

    // Page transition: toggle based on profile
    const pt = document.querySelector('.page-transition');
    if (pt) {
      if (profile.pageTransition) {
        pt.style.display = '';
        setupPageTransitions();
      } else {
        pt.style.display = 'none';
      }
    }

    // Parallax: setup/teardown
    if (profile.parallax) {
      setupParallax();
    } else {
      teardownParallax();
    }

    // Re-run reveal observer with new style
    refreshRevealObserver(profile.revealStyle);

    // Glitch effect on hero title
    toggleGlitch(profile.glitch);

    // Noise overlay
    toggleNoise(profile.noise);

    // Scanlines overlay
    toggleScanlines(profile.scanlines);

    // Magnetic cursor
    toggleMagnetic(profile.magnetic);

    // Floating cards
    toggleFloating(profile.floating);
  };

  // ============================================
  // GLITCH TEXT EFFECT
  // ============================================
  let glitchActive = false;
  function toggleGlitch(enable) {
    const heroTitle = document.querySelector('.hero-title, .page-header-title');
    if (!heroTitle) return;
    if (enable) {
      heroTitle.classList.add('glitch-text');
      heroTitle.setAttribute('data-text', heroTitle.textContent);
      glitchActive = true;
    } else {
      heroTitle.classList.remove('glitch-text');
      glitchActive = false;
    }
  }

  // ============================================
  // NOISE/GRAIN OVERLAY
  // ============================================
  function toggleNoise(enable) {
    let noiseEl = document.getElementById('noise-overlay');
    if (enable) {
      if (!noiseEl) {
        noiseEl = document.createElement('div');
        noiseEl.id = 'noise-overlay';
        noiseEl.setAttribute('aria-hidden', 'true');
        document.body.appendChild(noiseEl);
      }
      noiseEl.style.display = '';
    } else if (noiseEl) {
      noiseEl.style.display = 'none';
    }
  }

  // ============================================
  // SCANLINES OVERLAY
  // ============================================
  function toggleScanlines(enable) {
    let scanEl = document.getElementById('scanlines-overlay');
    if (enable) {
      if (!scanEl) {
        scanEl = document.createElement('div');
        scanEl.id = 'scanlines-overlay';
        scanEl.setAttribute('aria-hidden', 'true');
        document.body.appendChild(scanEl);
      }
      scanEl.style.display = '';
    } else if (scanEl) {
      scanEl.style.display = 'none';
    }
  }

  // ============================================
  // MAGNETIC CURSOR (attracts to interactive elements)
  // ============================================
  let magneticCleanup = null;
  function toggleMagnetic(enable) {
    if (magneticCleanup) { magneticCleanup(); magneticCleanup = null; }
    if (!enable) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(pointer: fine)').matches) return;

    const MAGNETIC_RADIUS = 80;
    const MAGNETIC_STRENGTH = 0.3;
    const interactives = document.querySelectorAll('a, button, .section-tab, .fact-card, .highlight-card, .timeline-item, .cta-btn');

    const onMove = (e) => {
      interactives.forEach(el => {
        const rect = el.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MAGNETIC_RADIUS) {
          const strength = (1 - dist / MAGNETIC_RADIUS) * MAGNETIC_STRENGTH;
          el.style.transform = `translate(${dx * strength}px, ${dy * strength}px)`;
        } else {
          el.style.transform = '';
        }
      });
    };
    const onLeave = () => interactives.forEach(el => el.style.transform = '');

    document.addEventListener('pointermove', onMove, { passive: true });
    document.addEventListener('pointerleave', onLeave);
    magneticCleanup = () => {
      document.removeEventListener('pointermove', onMove);
      document.removeEventListener('pointerleave', onLeave);
      interactives.forEach(el => el.style.transform = '');
    };
  }

  // ============================================
  // FLOATING CARDS — subtle drift animation + drag
  // ============================================
  let floatingCleanup = null;
  function toggleFloating(enable) {
    if (floatingCleanup) { floatingCleanup(); floatingCleanup = null; }
    const cards = document.querySelectorAll('.fact-card, .highlight-card, .timeline-item, .pub-card');
    if (!enable) {
      cards.forEach(c => { c.classList.remove('floating-card'); c.style.animationDelay = ''; c.style.transform = ''; });
      return;
    }
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    cards.forEach((card, i) => {
      card.classList.add('floating-card');
      // Stagger animation delays for organic feel
      card.style.setProperty('--float-delay', `${i * 0.8}s`);
      card.style.setProperty('--float-duration', `${4 + (i % 3)}s`);
      card.style.setProperty('--float-offset', `${(i % 2 === 0 ? 1 : -1) * (2 + i % 3)}px`);
      card.style.setProperty('--rotate-offset', `${(i % 2 === 0 ? 0.5 : -0.5) * (1 + (i % 3) * 0.3)}deg`);
    });

    // Drag functionality
    let dragTarget = null;
    let dragStartX = 0, dragStartY = 0;
    let cardStartX = 0, cardStartY = 0;
    let isDragging = false;

    function onPointerDown(e) {
      const card = e.target.closest('.floating-card');
      if (!card) return;
      // Don't drag if clicking a link or button inside the card
      if (e.target.closest('a, button')) return;
      
      dragTarget = card;
      const rect = card.getBoundingClientRect();
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      cardStartX = parseFloat(card.style.getPropertyValue('--drag-x')) || 0;
      cardStartY = parseFloat(card.style.getPropertyValue('--drag-y')) || 0;
      isDragging = false;
      
      card.style.zIndex = '10';
      card.style.transition = 'none';
      card.setPointerCapture(e.pointerId);
    }

    function onPointerMove(e) {
      if (!dragTarget) return;
      const dx = e.clientX - dragStartX;
      const dy = e.clientY - dragStartY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) isDragging = true;
      if (!isDragging) return;
      
      const newX = cardStartX + dx;
      const newY = cardStartY + dy;
      dragTarget.style.setProperty('--drag-x', `${newX}px`);
      dragTarget.style.setProperty('--drag-y', `${newY}px`);
      dragTarget.style.transform = `translate(${newX}px, ${newY}px)`;
      dragTarget.classList.add('is-dragging');
    }

    function onPointerUp(e) {
      if (!dragTarget) return;
      dragTarget.style.zIndex = '';
      dragTarget.style.transition = '';
      dragTarget.classList.remove('is-dragging');
      if (!isDragging) {
        // It was a click, not a drag — reset position
        dragTarget.style.setProperty('--drag-x', '0px');
        dragTarget.style.setProperty('--drag-y', '0px');
        dragTarget.style.transform = '';
      }
      dragTarget = null;
      isDragging = false;
    }

    document.addEventListener('pointerdown', onPointerDown);
    document.addEventListener('pointermove', onPointerMove);
    document.addEventListener('pointerup', onPointerUp);

    // Reset positions on page navigation
    const resetOnNav = () => cards.forEach(c => {
      c.style.setProperty('--drag-x', '0px');
      c.style.setProperty('--drag-y', '0px');
      c.style.transform = '';
    });
    window.addEventListener('beforeunload', resetOnNav);

    floatingCleanup = () => {
      document.removeEventListener('pointerdown', onPointerDown);
      document.removeEventListener('pointermove', onPointerMove);
      document.removeEventListener('pointerup', onPointerUp);
      window.removeEventListener('beforeunload', resetOnNav);
      cards.forEach(c => { c.classList.remove('floating-card'); c.style.transform = ''; });
    };
  }

  // ============================================
  // CURSOR — modes: 'none', 'trail', 'follower', 'square-follower'
  // ============================================
  let cursorRAF = null;
  let parallaxRAF = null;

  function initCursor(mode) {
    const cursorEl = document.querySelector('.cursor-trail');
    if (!cursorEl) return;

    // Cancel any running animation
    if (cursorRAF) { cancelAnimationFrame(cursorRAF); cursorRAF = null; }

    // Clean up previous listeners
    if (cursorEl._cleanup) { cursorEl._cleanup(); cursorEl._cleanup = null; }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
    const shouldEnable = hasFinePointer && !prefersReducedMotion;

    if (!shouldEnable || mode === 'none') {
      document.body.classList.remove('has-custom-cursor');
      cursorEl.style.display = 'none';
      return;
    }

    cursorEl.style.display = '';
    document.body.classList.add('has-custom-cursor');

    let latestX = window.innerWidth / 2;
    let latestY = window.innerHeight / 2;
    let renderedX = latestX;
    let renderedY = latestY;
    let isActive = false;

    const moveHandler = (e) => {
      latestX = e.clientX;
      latestY = e.clientY;
    };
    window.addEventListener('pointermove', moveHandler, { passive: true });

    if (mode === 'trail') {
      // Smooth trail: lerp with glow ring
      cursorEl.style.width = '48px';
      cursorEl.style.height = '48px';
      cursorEl.style.borderRadius = '50%';
      cursorEl.style.border = '';
      cursorEl.style.background = '';
      cursorEl.style.boxShadow = '';
      cursorEl.style.mixBlendMode = '';

      const animate = () => {
        renderedX += (latestX - renderedX) * 0.14;
        renderedY += (latestY - renderedY) * 0.14;
        cursorEl.style.transform = `translate3d(${renderedX - 24}px, ${renderedY - 24}px, 0)`;
        cursorRAF = requestAnimationFrame(animate);
      };
      cursorRAF = requestAnimationFrame(animate);

      // Active state on interactive elements
      const interactive = document.querySelectorAll('a, button, .section-tab, .fact-card, .highlight-card, .timeline-item, .pub-card, .social-link');
      const onEnter = () => cursorEl.classList.add('active');
      const onLeave = () => cursorEl.classList.remove('active');
      interactive.forEach(el => { el.addEventListener('mouseenter', onEnter); el.addEventListener('mouseleave', onLeave); });

      // Store cleanup
      cursorEl._cleanup = () => {
        window.removeEventListener('pointermove', moveHandler);
        interactive.forEach(el => { el.removeEventListener('mouseenter', onEnter); el.removeEventListener('mouseleave', onLeave); });
      };

    } else if (mode === 'follower') {
      // Small dot follower (Oliver9011 style)
      cursorEl.style.width = '12px';
      cursorEl.style.height = '12px';
      cursorEl.style.borderRadius = '50%';
      cursorEl.style.border = 'none';
      cursorEl.style.background = '';
      cursorEl.style.boxShadow = '';
      cursorEl.style.mixBlendMode = '';

      const animate = () => {
        renderedX += (latestX - renderedX) * 0.10;
        renderedY += (latestY - renderedY) * 0.10;
        cursorEl.style.transform = `translate3d(${renderedX - 6}px, ${renderedY - 6}px, 0)`;
        cursorRAF = requestAnimationFrame(animate);
      };
      cursorRAF = requestAnimationFrame(animate);

      // On hover, expand
      const interactive = document.querySelectorAll('a, button, .section-tab, .fact-card, .highlight-card, .timeline-item, .pub-card, .social-link, .cta-btn');
      const onEnter = () => cursorEl.classList.add('active');
      const onLeave = () => cursorEl.classList.remove('active');
      interactive.forEach(el => { el.addEventListener('mouseenter', onEnter); el.addEventListener('mouseleave', onLeave); });

      cursorEl._cleanup = () => {
        window.removeEventListener('pointermove', moveHandler);
        interactive.forEach(el => { el.removeEventListener('mouseenter', onEnter); el.removeEventListener('mouseleave', onLeave); });
      };

    } else if (mode === 'square-follower') {
      // Square follower: 8px square with 1px border-radius, expands on hover
      cursorEl.style.width = '8px';
      cursorEl.style.height = '8px';
      cursorEl.style.borderRadius = '1px';
      cursorEl.style.border = 'none';
      cursorEl.style.background = '';
      cursorEl.style.boxShadow = '';
      cursorEl.style.mixBlendMode = '';

      const animate = () => {
        renderedX += (latestX - renderedX) * 0.10;
        renderedY += (latestY - renderedY) * 0.10;
        cursorEl.style.transform = `translate3d(${renderedX - 4}px, ${renderedY - 4}px, 0)`;
        cursorRAF = requestAnimationFrame(animate);
      };
      cursorRAF = requestAnimationFrame(animate);

      // On hover, expand to 20px square with neon glow ring
      const interactive = document.querySelectorAll('a, button, .section-tab, .fact-card, .highlight-card, .timeline-item, .pub-card, .social-link, .cta-btn');
      const onEnter = () => cursorEl.classList.add('active');
      const onLeave = () => cursorEl.classList.remove('active');
      interactive.forEach(el => { el.addEventListener('mouseenter', onEnter); el.addEventListener('mouseleave', onLeave); });

      cursorEl._cleanup = () => {
        window.removeEventListener('pointermove', moveHandler);
        interactive.forEach(el => { el.removeEventListener('mouseenter', onEnter); el.removeEventListener('mouseleave', onLeave); });
      };
    }

    // Safe zone for language menu
    const safeZone = document.querySelector('.lang-menu');
    if (safeZone) {
      safeZone.addEventListener('pointerenter', () => document.body.classList.add('system-cursor-mode'));
      safeZone.addEventListener('pointerleave', () => document.body.classList.remove('system-cursor-mode'));
    }
  }

  // ============================================
  // PAGE TRANSITIONS
  // ============================================
  let pageTransitionsSetup = false;

  function setupPageTransitions() {
    if (pageTransitionsSetup) return;
    pageTransitionsSetup = true;

    const pt = document.querySelector('.page-transition');
    if (!pt) return;

    const setState = state => pt.classList.toggle('is-active', state);
    window.addEventListener('beforeunload', () => setState(true));

    document.querySelectorAll('a[href^="/"], a[href^="."]').forEach(anchor => {
      anchor.addEventListener('click', event => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || anchor.target === '_blank') return;
        const href = anchor.getAttribute('href');
        if (!href || href.startsWith('#')) return;
        event.preventDefault();
        setState(true);
        window.setTimeout(() => { window.location.href = anchor.href; }, 280);
      });
    });
  }

  // ============================================
  // PARALLAX
  // ============================================
  let parallaxActive = false;

  function setupParallax() {
    if (parallaxActive) return;
    parallaxActive = true;

    const scrollHandler = () => {
      if (parallaxRAF) cancelAnimationFrame(parallaxRAF);
      parallaxRAF = requestAnimationFrame(() => {
        const scrolled = window.pageYOffset;
        const hero = document.querySelector('.hero-content') || document.querySelector('.hero-inner');
        if (hero && scrolled < window.innerHeight) {
          hero.style.transform = `translateY(${scrolled * 0.2}px)`;
          hero.style.opacity = 1 - (scrolled / (window.innerHeight * 0.6));
        }
        parallaxRAF = null;
      });
    };

    window.addEventListener('scroll', scrollHandler, { passive: true });
    window.__parallaxCleanup = () => window.removeEventListener('scroll', scrollHandler);
  }

  function teardownParallax() {
    parallaxActive = false;
    if (window.__parallaxCleanup) {
      window.__parallaxCleanup();
      window.__parallaxCleanup = null;
    }
    // Reset hero transform
    const hero = document.querySelector('.hero-content') || document.querySelector('.hero-inner');
    if (hero) {
      hero.style.transform = '';
      hero.style.opacity = '';
    }
  }

  // ============================================
  // REVEAL OBSERVER
  // ============================================
  let revealObserver = null;

  function refreshRevealObserver(style) {
    // Destroy old observer
    if (revealObserver) {
      revealObserver.disconnect();
      revealObserver = null;
    }

    // Set data-reveal-style on body for CSS targeting
    document.body.setAttribute('data-reveal-style', style);

    const targets = document.querySelectorAll('[data-reveal]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasAnimation = typeof window.IntersectionObserver === 'function';
    const shouldAnimate = hasAnimation && !prefersReducedMotion;

    if (!shouldAnimate) {
      targets.forEach(el => el.classList.add('visible'));
      return;
    }

    revealObserver = new IntersectionObserver(
      entries => entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      }),
      { threshold: 0.01, rootMargin: '0px 0px -8% 0px' }
    );

    targets.forEach((el, i) => {
      el.style.setProperty('--reveal-delay', `${Math.min(i * 45, 300)}ms`);
      revealObserver.observe(el);
    });
  }

  // ============================================
  // Initialize on DOM ready
  // ============================================
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      const id = getCurrentThemeId();
      if (window.__applyThemeEffects) window.__applyThemeEffects(id);
    });
  } else {
    const id = getCurrentThemeId();
    if (window.__applyThemeEffects) window.__applyThemeEffects(id);
  }
</script>
